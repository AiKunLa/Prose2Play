{
  "name": "prose2play",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.30.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "db:down": "docker compose -f infra/docker/postgres.compose.yaml down -v",
    "db:generate": "pnpm exec drizzle-kit generate --config drizzle.config.ts",
    "db:health": "node scripts/db-health.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:up": "docker compose -f infra/docker/postgres.compose.yaml up -d",
    "dev": "pnpm -r --parallel --if-present dev",
    "prepare": "husky",
    "commitlint": "commitlint --config commitlint.config.cjs",
    "branch:check": "node scripts/check-branch-name.mjs",
    "pr:title:check": "node scripts/check-pr-title.mjs",
    "pr:body:check": "node scripts/check-pr-body.mjs",
    "changes:guard": "node scripts/check-changed-files.mjs",
    "lint": "node scripts/lint-workspace.mjs && node scripts/check-docs-structure.mjs && eslint .",
    "typecheck": "node scripts/typecheck-workspace.mjs && tsc -b --pretty false",
    "test": "node --test tests/**/*.test.mjs",
    "test:db": "node --test tests/database/*.test.mjs",
    "schema:check": "node scripts/schema-check.mjs",
    "docs:check": "node scripts/check-docs-structure.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm schema:check"
  }
}
